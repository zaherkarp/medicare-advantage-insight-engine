# MA Signal Monitor Configuration
# Copy this file to .env and fill in values.

# Webhook endpoint URL
# For ntfy.sh: https://ntfy.sh/your-topic-name (free, no signup)
# For Teams: your Teams incoming webhook URL
# For testing: https://webhook.site/<your-uuid> or similar inspector
WEBHOOK_URL=https://ntfy.sh/ma-signal-monitor

# Webhook mode: "ntfy", "generic", "teams", or "test"
# ntfy = push notifications via ntfy.sh (recommended — free, no signup)
# teams = Microsoft Teams Adaptive Cards
# generic = raw JSON to any endpoint
# test = logs payload without sending
WEBHOOK_MODE=ntfy

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Database path (relative to project root)
DB_PATH=data/state.db

# Config directory (relative to project root)
CONFIG_DIR=config

# Maximum items per source per run (0 = unlimited)
MAX_ITEMS_PER_SOURCE=50

# Minimum relevance score to trigger an alert (0.0 - 1.0)
MIN_RELEVANCE_SCORE=0.3

# Request timeout in seconds
REQUEST_TIMEOUT=30

# User agent for HTTP requests
USER_AGENT=MA-Signal-Monitor/1.0 (Educational/Research)
